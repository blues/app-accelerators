      "text": "{\n  \"file\": \"rtu_alert.qo\",\n  \"body\": {\n    \"alert\": \"delta_t_low\",\n    \"delta_t_f\": 8.2,\n    \"supply_f\": 48.1,\n    \"return_f\": 56.3\n  },\n  \"sync\": true\n}",
