    {
      "type": "text", "id": "therm_sup_label",
      "x": 90, "y": 210, "width": 340, "height": 100,
      "text": "Supply-air NTC 10k (β=3950)\n  +3V3 ─[10k series]─●─[NTC]─ GND\n                       │\n                       └─▶ A0\nProbe in supply duct ~12″ past coil",
